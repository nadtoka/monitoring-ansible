---
# Map custom environment variables to Ansible internal variables
# If the env variable is not set, it falls back to a generic example value
ansible_user: "{{ lookup('env', 'MON_SSH_USER') | default('user', true) }}"
ansible_ssh_private_key_file: "{{ lookup('env', 'MON_SSH_KEY') | default('~/.ssh/id_ed25519', true) }}"
ansible_become_password: "{{ lookup('env', 'MON_SUDO_PASS') }}" 

# Application variables
docker_compose_dir: "/home/{{ ansible_user }}/monitoring"

victoriametrics_version: "v1.101.0"
grafana_version: "10.4.1"

# Fetch Grafana admin password from the environment
grafana_admin_password: "{{ lookup('env', 'GRAFANA_ADMIN_PASSWORD') | default('example_password_123', true) }}"

# Ports for services
victoriametrics_port: 8428
grafana_port: 3000

# Read the variable. If it is not set in .env, use Google as a default example
monitored_sites_raw: "{{ lookup('env', 'MONITORED_SITES') | default('https://google.com', true) }}"

# Split the string into an array by comma
monitored_sites: "{{ monitored_sites_raw.split(',') }}"

# Monitoring server IP
server_ip: "{{ lookup('env', 'MON_SERVER_IP') }}"
